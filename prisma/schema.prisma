// Prisma schema for Synapse Portal
// Supports: Landing stats, Gardening app, extensible for future apps

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// Core / Shared
// ============================================================================

/// API keys for agent access
model ApiKey {
  id        String   @id @default(uuid())
  name      String   @unique // e.g., "racer-agent", "clark-agent"
  key       String   @unique // The actual API key
  scopes    String[] // Permissions: ["read", "write", "admin"]
  lastUsed  DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  isActive  Boolean  @default(true)
}

/// Daily stats for landing page
model DailyStat {
  id        String   @id @default(uuid())
  date      DateTime @unique @db.Date
  key       String   // e.g., "emails_processed", "bets_placed", "tasks_completed"
  value     Float
  metadata  Json?    // Additional context
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([date, key])
}

/// Notifications for landing page
model Notification {
  id        String   @id @default(uuid())
  type      String   // "info", "warning", "success", "error"
  title     String
  message   String
  source    String?  // Which app/source generated this
  isRead    Boolean  @default(false)
  isArchived Boolean @default(false)
  createdAt DateTime @default(now())
  
  @@index([isRead, createdAt])
}

// ============================================================================
// Gardening App
// ============================================================================

model GardenPlant {
  id            String   @id @default(uuid())
  name          String
  variety       String?
  category      String   // "vegetable", "herb", "flower", "fruit"
  description   String?
  sowIndoorStart Month?  // Earliest month to sow indoors (1-12)
  sowIndoorEnd   Month?  // Latest month to sow indoors
  sowOutdoorStart Month? // Earliest month to sow outdoors
  sowOutdoorEnd   Month? // Latest month to sow outdoors
  harvestStart   Month?  // Earliest harvest month
  harvestEnd     Month?  // Latest harvest month
  daysToGerminate Int?
  daysToHarvest   Int?
  spacingCm       Int?
  depthCm         Float?
  notes          String?
  imageUrl       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  
  plantings     GardenPlanting[]
  seedInventory SeedInventory[]

  @@index([category])
}

model GardenPlanting {
  id          String   @id @default(uuid())
  plantId     String
  plant       GardenPlant @relation(fields: [plantId], references: [id])
  location    String?  // "greenhouse", "bed-1", "pot-balcony"
  sowDate     DateTime @db.Date
  transplantDate DateTime? @db.Date
  expectedHarvestDate DateTime? @db.Date
  actualHarvestDate DateTime? @db.Date
  quantity    Int?
  status      PlantingStatus @default(sown)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([sowDate])
  @@index([status])
}

model SeedInventory {
  id          String   @id @default(uuid())
  plantId     String
  plant       GardenPlant @relation(fields: [plantId], references: [id])
  quantity    Int      // Number of seeds
  purchasedDate DateTime? @db.Date
  expiryDate  DateTime? @db.Date
  supplier    String?
  batchCode   String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([expiryDate])
}

model GardenTask {
  id          String   @id @default(uuid())
  title       String
  description String?
  dueDate     DateTime @db.Date
  completed   Boolean  @default(false)
  completedAt DateTime?
  recurring   String?  // "daily", "weekly", "monthly", null = one-off
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([dueDate, completed])
}

// ============================================================================
// Enums
// ============================================================================

enum Month {
  january
  february
  march
  april
  may
  june
  july
  august
  september
  october
  november
  december
}

enum PlantingStatus {
  sown
  germinated
  transplanted
  growing
  flowering
  fruiting
  harvested
  failed
}
