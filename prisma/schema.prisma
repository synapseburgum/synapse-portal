// Prisma schema for Synapse Portal
// Supports: Landing stats, Gardening app, extensible for future apps
// SQLite for dev, migrate to PostgreSQL for production

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================================================
// Core / Shared
// ============================================================================

/// API keys for agent access
model ApiKey {
  id        String   @id @default(uuid())
  name      String   @unique // e.g., "racer-agent", "clark-agent"
  key       String   @unique // The actual API key
  scopes    String   // JSON array: ["read", "write", "admin"]
  lastUsed  DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  isActive  Boolean  @default(true)
}

/// Daily stats for landing page
model DailyStat {
  id        String   @id @default(uuid())
  date      DateTime // SQLite stores as ISO string
  key       String   // e.g., "emails_processed", "bets_placed", "tasks_completed"
  value     Float
  metadata  String?  // JSON string for additional context
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([date, key])
}

/// Notifications for landing page
model Notification {
  id         String   @id @default(uuid())
  type       String   // "info", "warning", "success", "error"
  title      String
  message    String
  source     String?  // Which app/source generated this
  isRead     Boolean  @default(false)
  isArchived Boolean  @default(false)
  createdAt  DateTime @default(now())
}

// ============================================================================
// Gardening App
// ============================================================================

model GardenPlant {
  id              String   @id @default(uuid())
  name            String
  variety         String?
  category        String   // "vegetable", "herb", "flower", "fruit"
  description     String?
  sowIndoorStart  Int?     // 1-12 for month
  sowIndoorEnd    Int?
  sowOutdoorStart Int?
  sowOutdoorEnd   Int?
  harvestStart    Int?
  harvestEnd      Int?
  daysToGerminate Int?
  daysToHarvest   Int?
  spacingCm       Int?
  depthCm         Float?
  notes           String?
  imageUrl        String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  plantings     GardenPlanting[]
  seedInventory SeedInventory[]
}

model GardenPlanting {
  id                  String   @id @default(uuid())
  plantId             String
  plant               GardenPlant @relation(fields: [plantId], references: [id])
  location            String?  // "greenhouse", "bed-1", "pot-balcony"
  sowDate             DateTime
  transplantDate      DateTime?
  expectedHarvestDate DateTime?
  actualHarvestDate   DateTime?
  quantity            Int?
  status              String   @default("sown") // sown, germinated, transplanted, growing, flowering, fruiting, harvested, failed
  notes               String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model SeedInventory {
  id            String   @id @default(uuid())
  plantId       String
  plant         GardenPlant @relation(fields: [plantId], references: [id])
  quantity      Int      // Number of seeds
  purchasedDate DateTime?
  expiryDate    DateTime?
  supplier      String?
  batchCode     String?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model GardenTask {
  id          String    @id @default(uuid())
  title       String
  description String?
  dueDate     DateTime
  completed   Boolean   @default(false)
  completedAt DateTime?
  recurring   String?   // "daily", "weekly", "monthly", null = one-off
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}
